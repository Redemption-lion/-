<view class="container">
  <view class="notice-list">
    <view class="notice-item" wx:for="{{notices}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="item-header">
        <text class="title">{{item.title}}</text>
        <text class="top" wx:if="{{item.isTop === 1}}">置顶</text>
      </view>
      <text class="summary">{{item.content}}</text>
      <view class="item-footer">
        <text class="time">📅 {{item.createTime}}</text>
        <text class="views">👁️ {{item.viewCount || 0}}次阅读</text>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-more" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
  <view class="no-more" wx:if="{{!hasMore && notices.length > 0}}">
    <text>没有更多了</text>
  </view>
  <view class="empty" wx:if="{{!loading && notices.length === 0}}">
    <text>暂无公告</text>
  </view>
</view>