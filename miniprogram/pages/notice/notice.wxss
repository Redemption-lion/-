.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.notice-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.notice-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.notice-item:last-child {
  border-bottom: none;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-header .title {
  font-size: 30rpx;
  font-weight: bold;
  flex: 1;
}

.top {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  background: #fff3e0;
  color: #ff9800;
  border-radius: 8rpx;
}

.summary {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.item-footer {
  display: flex;
  gap: 30rpx;
  font-size: 22rpx;
  color: #999;
}

.loading-more, .no-more, .empty {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}