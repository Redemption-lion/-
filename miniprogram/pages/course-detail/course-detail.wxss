/* pages/course-detail/course-detail.wxss */
.container {
  min-height: 100vh;
  background: #f8f9fc;
  padding-bottom: 140rpx;
}

.cover {
  width: 100%;
  height: 480rpx;
  border-radius: 0 0 48rpx 48rpx;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.08);
}

.info-card {
  background: #fff;
  margin: 32rpx 24rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.03);
}

.course-name {
  font-size: 44rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
  color: #1e293b;
}

.tags {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.tag {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 60rpx;
  font-weight: 500;
}

.difficulty-beginner {
  background: #e8f5e9;
  color: #2e7d32;
}
.difficulty-intermediate {
  background: #fff3e0;
  color: #f57c00;
}
.difficulty-advanced {
  background: #ffebee;
  color: #d32f2f;
}
.category {
  background: #e3f2fd;
  color: #1565c0;
}
.status-active {
  background: #e8f5e9;
  color: #2e7d32;
}
.status-cancelled, .status-ended {
  background: #f5f5f5;
  color: #9e9e9e;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-top: 8rpx;
}

.price {
  font-size: 56rpx;
  color: #ef4444;
  font-weight: bold;
}

.original-price {
  font-size: 28rpx;
  color: #94a3b8;
  text-decoration: line-through;
}

.detail-card {
  background: #fff;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.03);
}

.detail-item {
  margin-bottom: 28rpx;
}

.detail-item .label {
  font-size: 28rpx;
  color: #475569;
  display: block;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.detail-item .value {
  font-size: 28rpx;
  color: #1e293b;
  display: block;
  line-height: 1.5;
}

progress {
  margin-top: 12rpx;
  border-radius: 8rpx;
}

.coach-card {
  background: #fff;
  margin: 24rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.03);
}

.coach-card .title {
  font-size: 30rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
  color: #1e293b;
}

.coach-info {
  display: flex;
  align-items: center;
}
.coach-info image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 2rpx solid #e2e8f0;
}
.coach-name {
  font-size: 30rpx;
  font-weight: bold;
  display: block;
  color: #1e293b;
}
.coach-bio {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 8rpx;
  display: block;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255,255,255,0.96);
  backdrop-filter: blur(20px);
  padding: 20rpx 32rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
  border-top: 1rpx solid rgba(0,0,0,0.05);
}

.btn {
  width: 100%;
  height: 96rpx;
  border-radius: 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  transition: all 0.2s;
}

.btn-book {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 8rpx 16rpx rgba(102,126,234,0.3);
}
.btn-cancel {
  background: #f1f5f9;
  color: #475569;
}
.btn-edit {
  background: #3b82f6;
  color: #fff;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  color: #94a3b8;
}