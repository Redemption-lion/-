/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: #f8f9fc;
  padding-bottom: 20rpx;
}

/* 头部区域 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 32rpx 80rpx;
  border-radius: 0 0 48rpx 48rpx;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.1);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.greeting {
  flex: 1;
}
.hello {
  font-size: 32rpx;
  color: rgba(255,255,255,0.9);
  display: block;
}
.name {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-top: 8rpx;
  display: block;
}

/* 头像：圆形，固定尺寸，图片自适应填充 */
.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: #e2e8f0;
  border: 2rpx solid rgba(255,255,255,0.4);
  flex-shrink: 0;
  margin-left: 20rpx;
}
.avatar image {
  width: 100%;
  height: 100%;
  display: block;
}

/* 轮播图 */
.banner {
  width: 100%;
  height: 320rpx;
  margin-top: -40rpx;
}
.banner image {
  width: 100%;
  height: 100%;
  border-radius: 32rpx;
}

/* 快捷入口 - 两列网格布局（会员端） */
.quick-entry.grid-2 {
  display: flex;
  flex-wrap: wrap;
  background: #fff;
  margin: 20rpx;
  padding: 20rpx 10rpx;
  border-radius: 32rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.04);
}
.quick-entry.grid-2 .entry-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  box-sizing: border-box;
}
.quick-entry.grid-2 .entry-icon {
  font-size: 56rpx;
  display: block;
  margin-bottom: 16rpx;
  background: #f0f4ff;
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50%;
  text-align: center;
  color: #667eea;
}
.quick-entry.grid-2 text {
  font-size: 26rpx;
  color: #334155;
  font-weight: 500;
}

/* 普通快捷入口（教练端，保持横向） */
.quick-entry:not(.grid-2) {
  display: flex;
  justify-content: space-around;
  background: #fff;
  margin: 20rpx;
  padding: 30rpx 0;
  border-radius: 32rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.04);
}
.quick-entry:not(.grid-2) .entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.quick-entry:not(.grid-2) .entry-icon {
  font-size: 52rpx;
  background: #f0f4ff;
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50%;
  text-align: center;
  color: #667eea;
}
.quick-entry:not(.grid-2) text {
  font-size: 24rpx;
  color: #475569;
}

/* 通用卡片样式 */
.section {
  background: #fff;
  margin: 24rpx;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.section-header .title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1e293b;
}
.section-header .more {
  font-size: 26rpx;
  color: #667eea;
}

.course-list {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}
.course-card {
  width: calc(50% - 12rpx);
  background: #ffffff;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  transition: transform 0.2s;
}
.course-card:active {
  transform: scale(0.98);
}
.course-card image {
  width: 100%;
  height: 220rpx;
  background: #e2e8f0;
}
.course-info {
  padding: 20rpx;
}
.course-name {
  font-size: 30rpx;
  font-weight: bold;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #1e293b;
}
.course-time {
  font-size: 24rpx;
  color: #64748b;
  display: block;
  margin-top: 8rpx;
}
.course-price {
  font-size: 32rpx;
  color: #ef4444;
  font-weight: bold;
  margin-top: 8rpx;
}

.notice-list {
  margin-top: 8rpx;
}
.notice-item {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}
.notice-title {
  font-size: 28rpx;
  color: #334155;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}
.notice-time {
  font-size: 24rpx;
  color: #94a3b8;
  margin-left: 20rpx;
}
.empty {
  text-align: center;
  padding: 60rpx;
  color: #94a3b8;
  font-size: 28rpx;
}

/* 教练端 */
.coach-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.1);
}
.coach-card image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.6);
  margin-right: 24rpx;
}
.coach-name {
  font-size: 36rpx;
  font-weight: bold;
}
.coach-bio {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
  display: block;
}

.today-course-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}
.today-course-item .course-name {
  font-size: 28rpx;
  font-weight: bold;
  width: 200rpx;
}
.today-course-item .course-time {
  font-size: 26rpx;
  color: #475569;
  flex: 1;
  text-align: center;
}
.today-course-item .course-count {
  font-size: 24rpx;
  color: #3b82f6;
}

.stats-row {
  display: flex;
  gap: 20rpx;
  margin: 24rpx;
}
.stat-card {
  flex: 1;
  background: #fff;
  padding: 32rpx;
  border-radius: 28rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
}
.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  display: block;
}
.stat-label {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 12rpx;
}