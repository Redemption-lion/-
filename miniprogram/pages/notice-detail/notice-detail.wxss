.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.notice-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  text-align: center;
  margin-bottom: 20rpx;
}

.info {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.divider {
  height: 1rpx;
  background: #eee;
  margin: 20rpx 0;
}

.content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  color: #999;
}