/* pages/profile/profile.wxss */
.container {
  min-height: 100vh;
  background: #f8f9fc;
  padding-bottom: 60rpx;
}

.user-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx;
  display: flex;
  align-items: center;
  border-radius: 0 0 48rpx 48rpx;
}
.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
  margin-right: 32rpx;
  background: #fff;
  position: relative;
  overflow: hidden;
}
.avatar image {
  width: 100%;
  height: 100%;
}
.avatar-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: white;
}
.user-info {
  flex: 1;
}
.username {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}
.role-badge {
  font-size: 26rpx;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 24rpx;
  border-radius: 60rpx;
  display: inline-block;
  margin-top: 12rpx;
  color: rgba(255,255,255,0.9);
}
.edit-btn {
  padding: 14rpx 32rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 60rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

.form-card {
  background: #fff;
  margin: 32rpx;
  padding: 36rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
}
.form-item {
  margin-bottom: 32rpx;
}
.form-item .label {
  font-size: 28rpx;
  color: #334155;
  display: block;
  margin-bottom: 12rpx;
  font-weight: 500;
}
.input, .picker {
  width: 100%;
  padding: 24rpx;
  background: #f1f5f9;
  border-radius: 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  color: #1e293b;
}
.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 16rpx rgba(102,126,234,0.3);
}

.menu-list {
  background: #fff;
  margin: 24rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #edf2f7;
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-item .icon {
  font-size: 44rpx;
  margin-right: 28rpx;
  width: 56rpx;
  text-align: center;
}
.menu-item .title {
  flex: 1;
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 500;
}
.menu-item .arrow {
  font-size: 32rpx;
  color: #cbd5e1;
}

.footer {
  padding: 40rpx;
  text-align: center;
}
.logout-btn {
  width: 100%;
  height: 96rpx;
  background: #fff;
  color: #ef4444;
  border-radius: 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: 1rpx solid #fee2e2;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
}
.version {
  font-size: 24rpx;
  color: #94a3b8;
}

/* ========== 新增上课记录样式 ========== */
.section {
  background: #fff;
  margin: 24rpx;
  border-radius: 32rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
}
.section-header {
  margin-bottom: 20rpx;
}
.section-header .title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1e293b;
}
.fitness-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}
.record-date {
  font-size: 26rpx;
  color: #64748b;
  width: 160rpx;
}
.course-name {
  font-size: 28rpx;
  color: #1e293b;
  flex: 1;
  margin-left: 20rpx;
}
.remark {
  font-size: 24rpx;
  color: #94a3b8;
}
.load-more {
  text-align: center;
  padding: 20rpx;
  color: #667eea;
  font-size: 26rpx;
}
.loading-text {
  text-align: center;
  padding: 20rpx;
  color: #94a3b8;
  font-size: 26rpx;
}
.empty {
  text-align: center;
  padding: 40rpx;
  color: #94a3b8;
  font-size: 28rpx;
}