/* 新增选项卡样式 */
.tabs {
  display: flex;
  background: #fff;
  margin: 20rpx 20rpx 0;
  border-radius: 60rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  font-weight: 500;
  color: #64748b;
  border-radius: 60rpx;
  transition: all 0.2s;
}
.tab-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(102,126,234,0.3);
}

/* 原有样式保留，微调间距 */
.container {
  min-height: 100vh;
  background: #f8f9fc;
  padding: 0 20rpx 20rpx;
}
.course-list {
  margin-top: 20rpx;
}
.course-card {
  background: #fff;
  border-radius: 28rpx;
  margin-bottom: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.history-card {
  opacity: 0.85;
}
.course-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.course-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #1e293b;
}
.status {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 60rpx;
}
.status-future {
  background: #e8f5e9;
  color: #2e7d32;
}
.status-past {
  background: #f1f5f9;
  color: #64748b;
}
.course-info {
  margin-bottom: 16rpx;
  display: flex;
  gap: 24rpx;
}
.time, .duration {
  font-size: 26rpx;
  color: #475569;
}
.course-stats {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.full-tag {
  background: #fee2e2;
  color: #ef4444;
  padding: 4rpx 16rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
}
.view-more {
  text-align: right;
  font-size: 26rpx;
  color: #667eea;
  margin-top: 8rpx;
}
.loading-more, .no-more, .empty {
  text-align: center;
  padding: 40rpx;
  color: #94a3b8;
  font-size: 28rpx;
}

/* 弹窗样式不变 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
}
.modal-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #edf2f7;
  font-size: 32rpx;
  font-weight: bold;
}
.close {
  font-size: 40rpx;
  color: #94a3b8;
  padding: 0 10rpx;
}
.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx 30rpx;
}
.member-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf2f7;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 16rpx;
}
.member-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1e293b;
  width: 160rpx;
}
.member-phone {
  font-size: 26rpx;
  color: #475569;
}
.member-remark {
  font-size: 24rpx;
  color: #94a3b8;
  width: 100%;
  margin-top: 8rpx;
}
.empty-members, .loading-text {
  text-align: center;
  padding: 40rpx;
  color: #94a3b8;
}
.modal-footer {
  padding: 20rpx 30rpx 40rpx;
}
.btn-close {
  background: #f1f5f9;
  color: #475569;
  border-radius: 60rpx;
  height: 80rpx;
  font-size: 30rpx;
  border: none;
}