/* pages/booking/booking.wxss */
.container {
  min-height: 100vh;
  background: #f8f9fc;
  padding-bottom: 20rpx;
}

.filter-bar {
  background: #fff;
  padding: 20rpx 30rpx;
  margin: 20rpx 20rpx 0;
  border-radius: 60rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}

.filter-picker {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.arrow {
  font-size: 22rpx;
  color: #999;
}

.booking-list {
  padding: 20rpx;
}

.booking-item {
  background: #fff;
  border-radius: 28rpx;
  margin-bottom: 24rpx;
  padding: 28rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.course-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a2c3e;
}

.status {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 40rpx;
  font-weight: 500;
}

.status-confirmed {
  background: #e8f5e9;
  color: #2e7d32;
}

.status-cancelled {
  background: #f5f5f5;
  color: #9e9e9e;
}

.status-completed {
  background: #e3f2fd;
  color: #1976d2;
}

.item-info {
  margin-bottom: 24rpx;
  background: #f8fafc;
  padding: 16rpx;
  border-radius: 20rpx;
}

.info-text {
  font-size: 26rpx;
  color: #546e7a;
  display: block;
  margin-bottom: 8rpx;
}

.item-actions {
  display: flex;
  gap: 20rpx;
}

.btn-view, .btn-cancel {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
  font-weight: 500;
}

.btn-view {
  background: #f1f5f9;
  color: #475569;
}

.btn-cancel {
  background: #fee2e2;
  color: #ef4444;
}

.loading-more, .no-more, .empty {
  text-align: center;
  padding: 40rpx;
  color: #94a3b8;
  font-size: 28rpx;
}