/* pages/my-courses/my-courses.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 20rpx;
}

.header-btn {
  padding: 20rpx;
}

.btn-add {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
}

.filter-bar {
  background: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}

.filter-picker {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.arrow {
  font-size: 22rpx;
  color: #999;
}

.course-list {
  padding: 20rpx;
}

.course-item {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #eee;
}

.course-name {
  font-size: 30rpx;
  font-weight: bold;
}

.status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.status-active {
  background: #e6f7e6;
  color: #4caf50;
}

.status-cancelled {
  background: #f0f0f0;
  color: #999;
}

.status-ended {
  background: #e3f2fd;
  color: #2196f3;
}

.item-info {
  margin-bottom: 20rpx;
}

.info-text {
  font-size: 26rpx;
  color: #666;
  display: inline-block;
  margin-right: 24rpx;
  margin-bottom: 8rpx;
}

.item-actions {
  display: flex;
  gap: 16rpx;
}

.btn-bookings, .btn-edit, .btn-delete, .btn-relist {
  flex: 1;
  height: 64rpx;
  font-size: 26rpx;
  border-radius: 32rpx;
  border: none;
}

.btn-bookings {
  background: #e3f2fd;
  color: #2196f3;
}

.btn-edit {
  background: #fff3e0;
  color: #ff9800;
}

.btn-delete {
  background: #ffe0e0;
  color: #f44336;
}

.btn-relist {
  background: #e3f2fd;
  color: #2196f3;
}

.loading-more, .no-more, .empty {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}