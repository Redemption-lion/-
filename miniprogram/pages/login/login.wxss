/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 80rpx 40rpx;
}

.tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 80rpx;
  margin-bottom: 50rpx;
  padding: 6rpx;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.7);
  border-radius: 60rpx;
  transition: all 0.3s;
}
.tab-item.active {
  background: #fff;
  color: #667eea;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.role-select {
  display: flex;
  gap: 30rpx;
  margin-bottom: 50rpx;
}
.role-item {
  flex: 1;
  text-align: center;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 60rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.3s;
}
.role-item.active {
  background: #fff;
  color: #667eea;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.15);
}

.form-container {
  background: #fff;
  border-radius: 48rpx;
  padding: 48rpx;
  box-shadow: 0 12rpx 40rpx rgba(0,0,0,0.1);
}

.input-group {
  position: relative;
  margin-bottom: 40rpx;
  background: #f2f4f8;
  border-radius: 60rpx;
}
.input {
  width: 100%;
  height: 96rpx;
  font-size: 30rpx;
  padding: 0 40rpx;
  box-sizing: border-box;
  background: transparent;
}
.eye-icon {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 36rpx;
  color: #94a3b8;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 60rpx;
  font-size: 34rpx;
  font-weight: bold;
  margin-top: 50rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(102,126,234,0.4);
}
.privacy {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
  font-size: 26rpx;
  color: #64748b;
}
.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #cbd5e1;
  border-radius: 10rpx;
  margin-right: 16rpx;
  background: #fff;
}
.checkbox.checked {
  background-color: #667eea;
  border-color: #667eea;
  position: relative;
}
.privacy-link {
  color: #667eea;
  margin-left: 8rpx;
  font-weight: 500;
}