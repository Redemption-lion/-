/** app.wxss **/
page {
  background-color: #f8f9fc;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #2c3e50;
}

/* 通用卡片样式 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

/* 主要按钮 */
.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 60rpx;
  font-size: 30rpx;
  font-weight: 500;
  padding: 24rpx 0;
  box-shadow: 0 8rpx 16rpx rgba(102, 126, 234, 0.3);
  transition: all 0.2s;
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 输入框 */
.input-group {
  background: #f2f4f8;
  border-radius: 20rpx;
  margin-bottom: 32rpx;
  transition: all 0.2s;
}

.input {
  height: 88rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  background: transparent;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #edf2f7;
  margin: 24rpx 0;
}

/* 列表项 */
.list-item {
  background: white;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}